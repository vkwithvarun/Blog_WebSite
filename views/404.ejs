<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
<title>404 · DevBlog</title>
<style>
  /* Custom Neon/Dark Theme Styles matching image_aca100.png */
  body {
    background-color: #0b0f19;
    color: #f8f9fa;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .error-container {
    background-color: #181d28;
    border: 2px solid #3caec3;
    border-radius: 1.25rem;
    padding: 3.5rem 2rem;
    box-shadow: 0 0 25px rgba(60, 174, 195, 0.25);
    max-width: 500px;
    width: 90%;
  }

  /* Neon Gradient Error Code */
  .error-code {
    background: linear-gradient(45deg, #7be1ec, #9b86f7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-size: 6rem;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 1rem;
    letter-spacing: 2px;
  }

  .error-message {
    color: #ccd6e6;
    font-size: 1.2rem;
    margin-bottom: 2rem;
  }

  /* Glowing Go Home Button */
  .btn-gohome {
    background: linear-gradient(90deg, #6fe3f3, #8ea5f9);
    border: none;
    color: #0b0f19;
    font-weight: 600;
    padding: 0.6rem 2.5rem;
    border-radius: 50px;
    box-shadow: 0 0 15px rgba(111, 227, 243, 0.4);
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
  }

  .btn-gohome:hover {
    background: linear-gradient(90deg, #8ea5f9, #6fe3f3);
    box-shadow: 0 0 25px rgba(111, 227, 243, 0.7);
    color: #0b0f19;
  }
</style>
</head>
<body>

<div class="error-container text-center">
  <div class="error-code">404</div>
  <p class="error-message">Oops! That page doesn't exist.</p>
  <a href="/" class="btn-gohome">Go Home</a>
</div>

<%- include('partials/scripts') %>
</body>
</html>