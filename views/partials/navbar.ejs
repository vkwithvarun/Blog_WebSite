    border-radius: 8px;
    box-shadow: 0 0 12px rgba(61, 136, 252, 0.4);
    transition: all 0.2s ease;
    display: inline-block;
  }
  .btn-signup-nav:hover {
    background-color: #3d88fc;
    box-shadow: 0 0 18px rgba(61, 136, 252, 0.7);
    color: #ffffff;
  }
</style>