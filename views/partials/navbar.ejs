<nav class="navbar navbar-expand-lg navbar-dark mb-4 py-3 custom-navbar">
  <div class="container">
    <!-- Brand Logo with Glowing Text and Icon -->
    <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/">
      <span class="brand-logo-icon">D</span> DevBlog
    </a>
    
    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
      <span class="navbar-toggler-icon"></span>
    </button>
    
    <div class="collapse navbar-collapse" id="navMenu">
      <!-- FIXED: Strict opt-in check ensures search form only renders if requested -->
      <% if (typeof showSearch !== 'undefined' && showSearch) { %>
        <form class="d-flex ms-4 position-relative my-3 my-lg-0 custom-search-form" method="GET" action="/" role="search">
          <input class="form-control search-input" type="search" name="q" placeholder="Search articles..." value="<%= typeof q !== 'undefined' ? q : '' %>">
          <button class="search-submit-btn" type="submit">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-search" viewBox="0 0 16 16">
              <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
            </svg>
          </button>
        </form>
      <% } %>
      
      <!-- Middle Navigation Links (Features, Blog, Support) -->
      <ul class="navbar-nav mx-auto mb-2 mb-lg-0 text-center gap-4">
        <li class="nav-item"><a class="nav-link custom-nav-link" href="#">Features</a></li>
        <li class="nav-item"><a class="nav-link custom-nav-link active" href="/">Blog</a></li>
        <li class="nav-item"><a class="nav-link custom-nav-link" href="#">Support</a></li>
      </ul>

      <!-- Right Side Auth Links -->
      <ul class="navbar-nav ms-auto align-items-center">

        <% if (currentUser) { %>

          <!-- Write Article -->
          <li class="nav-item me-3">
            <a href="/articles/new" class="nav-link text-info fw-semibold text-nowrap">
              + Write Article
            </a>
          </li>

          <!-- Username -->
          <li class="nav-item me-3">
            <span class="navbar-text text-light">
              Hi, <%= currentUser.username %>
            </span>
          </li>

          <!-- Logout -->
          <li class="nav-item">
            <form action="/logout" method="POST" class="m-0">
              <button type="submit" class="btn-signin-nav">
                Logout
              </button>
            </form>
          </li>

        <% } else { %>

          <li class="nav-item me-2">
            <a class="btn-signin-nav" href="/login">Sign In</a>
          </li>

          <li class="nav-item">
            <a class="btn-signup-nav" href="/signup">Sign Up</a>
          </li>

        <% } %>

      </ul>
    </div>
  </div>
</nav>

