  .custom-navbar {
    background-color: transparent !important;
    border-bottom: 1px solid #161c2a;
  }

  .brand-logo-icon {
    background: linear-gradient(135deg, #7be1ec, #9b86f7);
    color: #fff;
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    font-size: 1.1rem;
    font-weight: 800;
    box-shadow: 0 0 12px rgba(123, 225, 236, 0.4);
  }

  .custom-nav-link {
    color: #8fa0bc !important;
    font-weight: 500;
    font-size: 0.95rem;
    transition: color 0.2s ease;
  }
  .custom-nav-link:hover, .custom-nav-link.active {
    color: #ffffff !important;
  }

  .custom-search-form {
    width: 280px;
  }
  .search-input {
    background-color: #121824 !important;
    border: 1px solid #222d42 !important;
    color: #ffffff !important;
    border-radius: 50px !important;
    padding-left: 1.25rem;
    padding-right: 2.5rem;
    font-size: 0.9rem;
    height: 38px;
  }
  .search-input::placeholder {
    color: #526484;
  }
  .search-input:focus {
    box-shadow: 0 0 0 2px rgba(123, 225, 236, 0.25) !important;
    border-color: #3caec3 !important;
    color: #ffffff !important;
  }
  .search-submit-btn {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: #526484;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }
  .search-submit-btn:hover {
    color: #7be1ec;
  }

  .btn-signin-nav {
    color: #8699b5;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    background: none;
    border: none;
    padding: 0.4rem 1rem;
    transition: color 0.2s ease;
  }
  .btn-signin-nav:hover {
    color: #ffffff;
  }

  .btn-signup-nav {
    border: 1px solid #3d88fc;
