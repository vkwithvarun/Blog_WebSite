<% if (messages && messages.error && messages.error.length) { %>
  <% messages.error.forEach((msg) => { %>
    <div class="alert custom-neon-alert alert-danger-neon alert-dismissible fade show" role="alert">
      <div class="d-flex align-items-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-exclamation-triangle-fill me-2" viewBox="0 0 16 16">
          <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/>
        </svg>
        <div><%= msg %></div>
      </div>
      <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% }) %>
<% } %>

<% if (messages && messages.success && messages.success.length) { %>
  <% messages.success.forEach((msg) => { %>
    <div class="alert custom-neon-alert alert-success-neon alert-dismissible fade show" role="alert">
      <div class="d-flex align-items-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-check-circle-fill me-2" viewBox="0 0 16 16">
          <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
        </svg>
        <div><%= msg %></div>
      </div>
      <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% }) %>
<% } %>

<style>
  /* Cyberpunk / Neon Alert styling to match image_aca100.png */
  .custom-neon-alert {
    background-color: #121824 !important;
    border-width: 2px !important;
    border-radius: 0.75rem !important;
    color: #ffffff !important;
    margin-top: 1rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
  }

  /* Neon Red Error Style */
  .alert-danger-neon {
    border-color: #ff4a6b !important;
    box-shadow: 0 0 15px rgba(255, 74, 107, 0.25) !important;
  }
  .alert-danger-neon svg {
    color: #ff4a6b;
  }

  /* Neon Green Success Style */
  .alert-success-neon {
    border-color: #3ee0a4 !important;
    box-shadow: 0 0 15px rgba(62, 224, 164, 0.25) !important;
  }
  .alert-success-neon svg {
    color: #3ee0a4;
  }
</style>