<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="/css/style.css">
<title>New Article · DevBlog</title>
<style>
  /* Base Theme Layout Rules Matching image_b85f07.png */
  body {
    background-color: #0b0f19;
    color: #f8f9fa;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* Translucent Cyberpunk Form Container Card */
  .form-wrapper-card {
    background-color: #181d28;
    border: 2px solid #3caec3;
    border-radius: 1.25rem;
    box-shadow: 0 0 25px rgba(60, 174, 195, 0.2);
    padding: 3rem 2.5rem;
    margin-top: 2rem;
    margin-bottom: 4rem;
  }

  /* Gradient Header Text style */
  .form-page-title {
    font-size: 2.5rem;
    font-weight: 700;
    background: linear-gradient(45deg, #7be1ec, #9b86f7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 2rem;
    letter-spacing: 0.5px;
  }
</style>
</head>
<body>
<!-- Integrated Navbar Component Structure (Hides search dynamically via global showSearch parameter) -->
<%- include('../partials/navbar') %>

<div class="container flex-grow-1">
  <%- include('../partials/messages') %>
  
  <div class="form-wrapper-card">
    <h1 class="form-page-title">New Article</h1>
    
    <form action="/articles" method="POST">
      <!-- Nested dynamic fields injector styled to match your theme layout -->
      <%- include('form_field') %>
    </form>
  </div>
</div>

<%- include('../partials/scripts') %>
</body>
</html>