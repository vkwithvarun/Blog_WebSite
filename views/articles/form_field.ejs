<style>
  /* Cyber Form Controls Overrides */
  .custom-form-group label {
    display: block;
    color: #ccd6e6;
    margin-bottom: 0.5rem;
    font-size: 0.95rem;
    font-weight: 500;
  }

  .custom-form-group .form-control {
    background-color: #0b0f19 !important;
    border: 1px solid #333d52 !important;
    color: #ffffff !important;
    border-radius: 8px !important;
    padding: 0.75rem 1rem;
    transition: all 0.3s ease;
  }

  .custom-form-group .form-control:focus {
    background-color: #0b0f19 !important;
    border-color: #3caec3 !important;
    box-shadow: 0 0 14px rgba(60, 174, 195, 0.35) !important;
    outline: none;
  }

  .custom-form-group .form-control::placeholder {
    color: #475569;
  }

  /* Dual Tone Neon Action Buttons */
  .btn-cyber-save {
    background: linear-gradient(90deg, #6fe3f3, #8ea5f9);
    border: none;
    color: #0b0f19;
    font-weight: 600;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    box-shadow: 0 0 15px rgba(111, 227, 243, 0.4);
    transition: all 0.3s ease;
  }

  .btn-cyber-save:hover {
    background: linear-gradient(90deg, #8ea5f9, #6fe3f3);
    box-shadow: 0 0 25px rgba(111, 227, 243, 0.7);
    color: #0b0f19;
  }

  .btn-cyber-cancel {
    background: transparent;
    border: 1px solid #333d52;
    color: #8fa0bc;
    font-weight: 500;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
  }

  .btn-cyber-cancel:hover {
    border-color: #717d93;
    color: #ffffff;
  }
</style>

<div class="form-group custom-form-group mb-4">
  <label for="title">Title</label>
  <input required value="<%= article.title %>" type="text" name="title" id="title" class="form-control" placeholder="Enter article title">
</div>

<div class="form-group custom-form-group mb-4">
  <label for="description">Description</label>
  <textarea name="description" id="description" class="form-control" rows="3" placeholder="Brief summary of the article"><%= article.description %></textarea>
</div>

<div class="form-group custom-form-group mb-4">
  <label for="tags">Tags <small style="color: #717d93; font-size: 0.8rem;">(comma separated)</small></label>
  <input value="<%= article.tags ? article.tags.join(', ') : '' %>" type="text" name="tags" id="tags" class="form-control" placeholder="javascript, nodejs, mongodb">
</div>

<div class="form-group custom-form-group mb-4">
  <label for="markdown">Markdown Content</label>
  <textarea required name="markdown" id="markdown" class="form-control" rows="12" placeholder="Write your article content in Markdown format..."><%= article.markdown %></textarea>
</div>

<div class="d-flex gap-3 align-items-center mt-4">
  <a href="/" class="btn-cyber-cancel">Cancel</a>
  <button type="submit" class="btn btn-cyber-save">Save Article</button>
</div>