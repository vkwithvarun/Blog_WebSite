<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="/css/style.css">
<title>DevBlog</title>
<style>
  body {
    background-color: #0b0f19;
    color: #f8f9fa;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .hero-heading {
    background: linear-gradient(45deg, #7be1ec, #9b86f7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 700;
    font-size: 2.5rem;
    text-align: center;
    margin-top: 2.5rem;
    margin-bottom: 2.5rem;
    letter-spacing: 0.5px;
  }

  .article-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }

  @media (max-width: 576px) {
    .article-grid {
      grid-template-columns: 1fr;
    }
  }

  .blog-card {
    background-color: #181d28;
    border: 2px solid #3caec3;
    border-radius: 1.25rem;
    box-shadow: 0 0 15px rgba(60, 174, 195, 0.2);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .blog-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 0 25px rgba(60, 174, 195, 0.45);
  }

  .blog-card .card-title {
    color: #ffffff;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }

  .blog-card .card-subtitle {
    color: #717d93 !important;
    font-size: 0.9rem;
  }

  .tag-badge {
    background-color: #242b3b !important;
    color: #a3b3cc !important;
    border: 1px solid #333d52;
    padding: 0.4rem 0.75rem;
    border-radius: 50px;
    font-weight: 500;
    font-size: 0.8rem;
    text-transform: lowercase;
  }

  .blog-card .card-text {
    color: #ccd6e6;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .btn-readmore {
    background: linear-gradient(90deg, #6fe3f3, #8ea5f9);
    border: none;
    color: #0b0f19;
    font-weight: 600;
    padding: 0.5rem 1.75rem;
    border-radius: 50px;
    box-shadow: 0 0 15px rgba(111, 227, 243, 0.4);
    transition: all 0.3s ease;
    display: inline-block;
    text-decoration: none;
  }

  .btn-readmore:hover {
    background: linear-gradient(90deg, #8ea5f9, #6fe3f3);
    box-shadow: 0 0 22px rgba(111, 227, 243, 0.7);
    color: #0b0f19;
  }

  .tech-stack-wrapper {
    background-color: #121620;
    border: 1px solid #222d42;
    border-radius: 12px;
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    padding: 6px;
  }

  .tech-stack-wrapper img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .admin-actions {
    border-top: 1px solid #242b3b;
    padding-top: 1rem;
    margin-top: 1rem;
  }

  .pagination .page-link {
    background-color: #181d28;
    border-color: #242b3b;
    color: #6fe3f3;
  }
  .pagination .page-item.active .page-link {
    background-color: #3caec3;
    border-color: #3caec3;
    color: #0b0f19;
  }
</style>
</head>
<body>
<%- include('../partials/navbar') %>

<div class="container flex-grow-1">
  <%- include('../partials/messages') %>

  <h1 class="hero-heading">Engineering Insights & Tech Innovations</h1>

  <% if (typeof q !== 'undefined' && q) { %>
    <p class="text-muted mb-4">Search results for "<%= q %>" — <%= articles.length %> found</p>
  <% } %>

  <% if (articles.length === 0) { %>
    <div class="text-center text-muted mt-5">
      <h4>No articles yet</h4>
      <p>Be the first to <a href="/articles/new" class="text-info">write one</a>.</p>
    </div>
  <% } %>

  <div class="article-grid">
    <% articles.forEach((article) => { %>
      <div class="card blog-card">
        <div class="card-body d-flex flex-column justify-content-between p-4">
          <div>
            <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
              <h4 class="card-title mb-0"><%= article.title %></h4>
              
              <% if (article.techIcon) { %>
                <div class="tech-stack-wrapper">
                  <img src="/images/stacks/<%= article.techIcon %>" alt="tech-stack">
                </div>
              <% } else { %>
                <div class="tech-stack-wrapper">
                  <span class="text-muted small" style="font-size: 0.65rem;">DEV</span>
                </div>
              <% } %>
            </div>

            <div class="card-subtitle mb-3">
              <%= article.createdAt.toLocaleDateString() %>
            </div>
            
            <% if (article.tags && article.tags.length) { %>
              <div class="mb-3 d-flex flex-wrap gap-2">
                <% article.tags.forEach((tag) => { %>
                  <span class="badge tag-badge"><%= tag %></span>
                <% }) %>
              </div>
            <% } %>
            
            <p class="card-text mb-4"><%= article.description %></p>
          </div>

          <div>
            <div class="d-flex justify-content-between align-items-center">
              <a href="/articles/<%= article.slug %>" class="btn-readmore">Read More</a>
            </div>

            <% if (typeof currentUser !== 'undefined' && currentUser && article.author && article.author.toString() === currentUser.id) { %>
              <div class="admin-actions d-flex gap-2">
                <a href="/articles/edit/<%= article.id %>" class="btn btn-outline-info btn-sm rounded-pill px-3">Edit</a>
                <form action="/articles/<%= article.id %>?_method=DELETE" method="POST" class="d-inline">
                  <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">Delete</button>
                </form>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
    <nav class="mb-5">
      <ul class="pagination justify-content-center">
        <% for (let i = 1; i <= totalPages; i++) { %>
          <li class="page-item <%= i === page ? 'active' : '' %>">
            <a class="page-link" href="/?page=<%= i %><%= (typeof q !== 'undefined' && q) ? '&q=' + q : '' %>"><%= i %></a>
          </li>
        <% } %>
      </ul>
    </nav>
  <% } %>
</div>

<%- include('../partials/scripts') %>
</body>
</html>