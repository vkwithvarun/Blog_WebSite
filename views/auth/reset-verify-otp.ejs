<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Verify Code · DevBlog</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
<!-- Bootstrap Icons for the security shield input icon -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link rel="stylesheet" href="/css/style.css">
<style>
  /* --- CYBERPUNK DARK THEME ROOT --- */
  body {
    background: radial-gradient(circle at 80% 80%, #1e2230 0%, #0f111a 100%);
    color: #a5b4fc;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    font-family: system-ui, -apple-system, sans-serif;
  }

  /* --- MODERN GLOWING NAVBAR --- */
  .custom-navbar {
    background-color: #0f111a;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding: 0.85rem 2rem;
  }

  /* Pure CSS Project Logo */
  .logo-container {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none !important;
  }

  .logo-icon {
    position: relative;
    width: 32px;
    height: 32px;
    background: linear-gradient(135deg, #38bdf8 0%, #a855f7 100%);
    border-radius: 8px 16px 16px 8px;
    box-shadow: 0 0 15px rgba(56, 189, 248, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-icon::before {
    content: "";
    width: 14px;
    height: 14px;
    background-color: #0f111a;
    border-radius: 4px 8px 8px 4px;
  }

  .logo-icon::after {
    content: "";
    position: absolute;
    left: 0;
    top: 25%;
    width: 6px;
    height: 50%;
    background: #ffffff;
    border-radius: 0 4px 4px 0;
    opacity: 0.8;
  }

  .logo-text {
    font-size: 1.4rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: -0.5px;
  }
  
  /* Navigation Menu Link Alignment */
  .custom-nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin: 0 auto;
    list-style: none;
    padding: 0;
  }

  .custom-nav-link {
    color: #94a3b8;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .custom-nav-link:hover {
    color: #ffffff;
  }

  .custom-nav-link.active {
    color: #3b82f6;
    position: relative;
  }

  .custom-nav-link.active::after {
    content: "";
    position: absolute;
    bottom: -22px;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: #3b82f6;
    box-shadow: 0 0 8px #3b82f6;
  }

  .btn-signin {
    background: transparent;
    border: 1px solid rgba(99, 102, 241, 0.4);
    color: #ffffff;
    padding: 0.5rem 1.25rem;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 500;
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .btn-signin:hover {
    background: rgba(99, 102, 241, 0.1);
    border-color: #38bdf8;
    box-shadow: 0 0 12px rgba(56, 189, 248, 0.3);
    color: #ffffff;
  }

  /* --- INTERFACE CARD LAYOUT --- */
  .card-wrapper {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 0;
    position: relative;
  }

  /* Bottom Right Glowing Geometric Background Sparkle */
  .card-wrapper::after {
    content: "✦";
    position: absolute;
    bottom: 15%;
    right: 20%;
    color: #7dd3fc;
    font-size: 2rem;
    opacity: 0.5;
    filter: drop-shadow(0 0 8px #38bdf8);
  }

  .neon-card {
    background: rgba(20, 24, 38, 0.6);
    border: 1px solid rgba(99, 102, 241, 0.25);
    border-radius: 16px;
    padding: 3.5rem 3rem;
    width: 100%;
    max-width: 480px;
    box-shadow: 0 0 40px rgba(99, 102, 241, 0.15);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .neon-card h1 {
    font-size: 2.5rem;
    font-weight: 700;
    background: linear-gradient(45deg, #38bdf8, #a855f7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 1.5rem;
    text-align: left;
  }

  .neon-card .text-muted {
    color: #94a3b8 !important;
    font-size: 1rem;
    margin-bottom: 2rem;
    text-align: left;
    line-height: 1.5;
  }

  .form-group label {
    display: block;
    text-align: left;
    color: #cbd5e1;
    margin-bottom: 0.5rem;
    font-size: 0.95rem;
  }

  /* Input wrapper box styling */
  .input-icon-wrapper {
    position: relative;
  }

  .input-icon-wrapper i {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: #64748b;
    font-size: 1.1rem;
  }

  .neon-card .form-control {
    background-color: rgba(15, 17, 26, 0.75);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: #ffffff;
    border-radius: 8px;
    padding: 0.8rem 0.8rem 0.8rem 2.6rem;
    transition: all 0.3s ease;
  }

  .neon-card .form-control:focus {
    background-color: rgba(15, 17, 26, 0.95);
    border-color: #38bdf8;
    box-shadow: 0 0 14px rgba(56, 189, 248, 0.35);
    color: #ffffff;
    outline: none;
  }

  .neon-card .form-control::placeholder {
    color: #475569;
  }

  /* Linear Neon Action Button */
  .btn-gradient {
    background: linear-gradient(90deg, #0284c7, #7c3aed);
    border: none;
    color: #ffffff;
    padding: 0.8rem;
    font-weight: 600;
    border-radius: 30px;
    width: 100%;
    margin-top: 2rem;
    margin-bottom: 1.5rem;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(124, 58, 237, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }

  .btn-gradient:hover {
    opacity: 0.95;
    box-shadow: 0 4px 25px rgba(56, 189, 248, 0.55);
    color: #ffffff;
  }

  .neon-card a {
    color: #3b82f6;
    text-decoration: none;
    transition: color 0.2s ease;
    font-size: 0.95rem;
    font-weight: 500;
  }

  .neon-card a:hover {
    color: #38bdf8;
    text-decoration: underline;
  }
</style>
</head>
<body>

<!-- COMPONENT: INTERACTIVE NAV BAR -->
<nav class="navbar custom-navbar">
  <div class="container-fluid d-flex align-items-center justify-content-between">
    
    <!-- CSS Vector Design Logo Element -->
    <a href="/" class="logo-container">
      <div class="logo-icon"></div>
      <span class="logo-text">DevBlog</span>
    </a>

    <!-- Menu Links List -->
    <ul class="custom-nav-links d-none d-md-flex">
      <li><a href="/signup" class="custom-nav-link">Sign Up</a></li>
      <li><a href="/features" class="custom-nav-link">Features</a></li>
      <li><a href="/blog" class="custom-nav-link">Blog</a></li>
      <li><a href="/support" class="custom-nav-link">Support</a></li>
    </ul>

    <!-- Sign In Action Button -->
    <div class="nav-auth-group">
      <a href="/login" class="btn-signin">Sign In</a>
    </div>

  </div>
</nav>

<!-- COMPONENT: OTP VERIFICATION VIEW -->
<div class="card-wrapper">
  <div class="neon-card">
    <%- include('../partials/messages') %>
    
    <h1>Enter reset code</h1>
    <p class="text-muted">Enter the 6-digit code we sent to your email. It expires in 5 minutes.</p>
    
    <form action="/reset-verify-otp" method="POST">
      <div class="form-group mb-3">
        <label for="otp">Reset code</label>
        <div class="input-icon-wrapper">
          <i class="bi bi-shield-lock"></i>
          <input required maxlength="6" pattern="[0-9]{6}" type="text" name="otp" id="otp" class="form-control" placeholder="e.g., 123456" autocomplete="one-time-code">
        </div>
      </div>
      
      <button type="submit" class="btn btn-gradient">
        Verify code <i class="bi bi-chevron-right" style="font-size: 0.8rem;"></i>
      </button>
    </form>
    
    <div class="text-center mt-3">
      <a href="/forgot-password">Request a new code</a>
    </div>
  </div>
</div>

<%- include('../partials/scripts') %>
</body>
</html>