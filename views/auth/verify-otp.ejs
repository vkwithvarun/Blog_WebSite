<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="/css/style.css">
<title>Verify Email · DevBlog</title>
</head>
<body>
<%- include('../partials/navbar') %>
<div class="container" style="max-width:480px;">
  <%- include('../partials/messages') %>
  <h1 class="mb-3">Verify your email</h1>
  <p class="text-muted">Enter the 6-digit code we sent to your email. It expires in 5 minutes.</p>
  <form action="/verify-otp" method="POST">
    <div class="form-group mb-3">
      <label for="otp">Verification code</label>
      <input required maxlength="6" pattern="[0-9]{6}" type="text" name="otp" id="otp" class="form-control" placeholder="123456" autocomplete="one-time-code">
    </div>
    <button type="submit" class="btn btn-primary">Verify</button>
  </form>
  <form action="/resend-otp" method="POST" class="mt-3">
    <button type="submit" class="btn btn-link p-0">Resend code</button>
  </form>
</div>
<%- include('../partials/scripts') %>
</body>
</html>