<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Login · DevBlog</title>
<!-- Bootstrap 5 & Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link rel="stylesheet" href="/css/style.css">

<style>
  /* --- GLOBAL DESIGN STYLES --- */
  body {
    background-color: #0b0f19;
    color: #f8f9fa;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  }

  /* --- LOGIN BOX LAYOUT & COMPONENTS --- */
  .login-wrapper {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 0;
    position: relative;
  }

  /* Decorative Background Star matching image_aca100.png design */
  .login-wrapper::after {
    content: "✦";
    position: absolute;
    bottom: 15%;
    right: 25%;
    color: #6fe3f3;
    font-size: 2rem;
    opacity: 0.6;
    filter: drop-shadow(0 0 8px rgba(111, 227, 243, 0.6));
  }

  /* Main Container Box matching card layouts */
  .login-card {
    background-color: #181d28;
    border: 2px solid #3caec3;
    border-radius: 1.25rem;
    padding: 3.5rem 3rem;
    width: 100%;
    max-width: 480px;
    box-shadow: 0 0 25px rgba(60, 174, 195, 0.25);
  }

  /* Gradient Login Title Header Text */
  .login-card h1 {
    font-size: 2.5rem;
    font-weight: 700;
    background: linear-gradient(45deg, #7be1ec, #9b86f7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 2rem;
    text-align: center;
    letter-spacing: 0.5px;
  }

  .form-group label {
    display: block;
    text-align: left;
    color: #ccd6e6;
    margin-bottom: 0.5rem;
    font-size: 0.95rem;
  }

  /* Field Icon Wrappers */
  .input-icon-wrapper {
    position: relative;
  }

  .input-icon-wrapper i {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: #717d93;
    font-size: 1.1rem;
  }

  /* Cyber Input Fields Overrides */
  .login-card .form-control {
    background-color: #0b0f19;
    border: 1px solid #333d52;
    color: #ffffff;
    border-radius: 8px;
    padding: 0.8rem 0.8rem 0.8rem 2.6rem;
    transition: all 0.3s ease;
  }

  .login-card .form-control:focus {
    background-color: #0b0f19;
    border-color: #3caec3;
    box-shadow: 0 0 14px rgba(60, 174, 195, 0.35);
    color: #ffffff;
    outline: none;
  }

  .login-card .form-control::placeholder {
    color: #475569;
  }

  /* Glowing Linear Action Button */
  .btn-gradient {
    background: linear-gradient(90deg, #6fe3f3, #8ea5f9);
    border: none;
    color: #0b0f19;
    padding: 0.8rem;
    font-weight: 600;
    border-radius: 30px;
    width: 100%;
    margin-top: 2rem;
    margin-bottom: 1.5rem;
    transition: all 0.3s ease;
    box-shadow: 0 0 15px rgba(111, 227, 243, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }

  .btn-gradient:hover {
    background: linear-gradient(90deg, #8ea5f9, #6fe3f3);
    box-shadow: 0 0 25px rgba(111, 227, 243, 0.7);
    color: #0b0f19;
  }

  /* Anchor Links Configuration */
  .login-card a {
    color: #6fe3f3;
    text-decoration: none;
    transition: color 0.2s ease;
    font-size: 0.95rem;
  }

  .login-card a:hover {
    color: #8ea5f9;
    text-decoration: underline;
  }

  .signup-text {
    color: #717d93;
    margin-top: 1.5rem;
    font-size: 0.95rem;
    text-align: center;
  }

  .signup-text a {
    color: #6fe3f3;
    font-weight: 600;
  }
</style>
</head>
<body>

<!-- Integrated Navbar Partial Component -->
<%- include('../partials/navbar') %>

<!-- MAIN CARD MODULE -->
<div class="login-wrapper">
  <div class="login-card">
    <!-- Server Message Injection Mount Point -->
    <%- include('../partials/messages') %>
    
    <h1>Login</h1>
    
    <form action="/login" method="POST">
      <!-- Username Field Box Block -->
      <div class="form-group mb-4">
        <label for="username">Username or Email</label>
        <div class="input-icon-wrapper">
          <i class="bi bi-person"></i>
          <input required type="text" name="username" id="username" class="form-control" placeholder="e.g., username or email">
        </div>
      </div>
      
      <!-- Password Field Box Block -->
      <div class="form-group mb-4">
        <label for="password">Password</label>
        <div class="input-icon-wrapper">
          <i class="bi bi-key"></i>
          <input required type="password" name="password" id="password" class="form-control" placeholder="e.g., password">
        </div>
      </div>
      
      <!-- Submissions Form Controls -->
      <button type="submit" class="btn btn-gradient">
        Login <i class="bi bi-chevron-right" style="font-size: 0.8rem;"></i>
      </button>
    </form>
    
    <div class="text-center mt-2">
      <a href="/forgot-password">Forgot password?</a>
    </div>
    
    <div class="signup-text">
      Don't have an account? <a href="/signup">Sign up</a>
    </div>
  </div>
</div>

<%- include('../partials/scripts') %>
</body>
</html>