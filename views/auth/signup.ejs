<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sign Up · DevBlog</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link rel="stylesheet" href="/css/style.css">
<style>
  body {
    background-color: #0b0f19;
    color: #f8f9fa;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  }
  .login-wrapper {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 0;
    position: relative;
  }
  .login-card {
    background-color: #181d28;
    border: 2px solid #3caec3;
    border-radius: 1.25rem;
    padding: 3.5rem 3rem;
    width: 100%;
    max-width: 480px;
    box-shadow: 0 0 25px rgba(60, 174, 195, 0.25);
  }
  .login-card h1 {
    font-size: 2.5rem;
    font-weight: 700;
    background: linear-gradient(45deg, #7be1ec, #9b86f7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 2rem;
    text-align: center;
  }
  .form-group label {
    display: block;
    text-align: left;
    color: #ccd6e6;
    margin-bottom: 0.5rem;
  }
  .input-icon-wrapper { position: relative; }
  .input-icon-wrapper i {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: #717d93;
  }
  .login-card .form-control {
    background-color: #0b0f19;
    border: 1px solid #333d52;
    color: #ffffff;
    border-radius: 8px;
    padding: 0.8rem 0.8rem 0.8rem 2.6rem;
  }
  .login-card .form-control:focus {
    background-color: #0b0f19;
    border-color: #3caec3;
    box-shadow: 0 0 14px rgba(60, 174, 195, 0.35);
  }
  .btn-gradient {
    background: linear-gradient(90deg, #6fe3f3, #8ea5f9);
    border: none;
    color: #0b0f19;
    padding: 0.8rem;
    font-weight: 600;
    border-radius: 30px;
    width: 100%;
    margin-top: 2rem;
    box-shadow: 0 0 15px rgba(111, 227, 243, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }
  .login-card a { color: #6fe3f3; text-decoration: none; }
  .login-card a:hover { text-decoration: underline; }
</style>
</head>
<body>

<%- include('../partials/navbar') %>

<div class="login-wrapper">
  <div class="login-card">
    <%- include('../partials/messages') %>
    <h1>Sign Up</h1>
    <form action="/signup" method="POST">
      <div class="form-group mb-3">
        <label for="username">Username</label>
        <div class="input-icon-wrapper">
          <i class="bi bi-person"></i>
          <input required type="text" name="username" id="username" class="form-control" placeholder="Choose a username">
        </div>
      </div>
      <div class="form-group mb-3">
        <label for="email">Email Address</label>
        <div class="input-icon-wrapper">
          <i class="bi bi-envelope"></i>
          <input required type="email" name="email" id="email" class="form-control" placeholder="name@example.com">
        </div>
      </div>
      <div class="form-group mb-4">
        <label for="password">Password</label>
        <div class="input-icon-wrapper">
          <i class="bi bi-key"></i>
          <input required type="password" name="password" id="password" class="form-control" placeholder="Create a password">
        </div>
      </div>
      <button type="submit" class="btn btn-gradient">Register</button>
    </form>
    <div class="text-center mt-4 text-muted small">
      Already have an account? <a href="/login" class="fw-bold">Sign In</a>
    </div>
  </div>
</div>

<%- include('../partials/scripts') %>
</body>
</html>